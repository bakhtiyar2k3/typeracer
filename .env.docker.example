# Copy to `.env` for docker compose:  cp .env.docker.example .env
# Compose substitutes these into the services (see docker-compose.yml).

# REQUIRED — a long, random secret. Generate one, e.g.:
#   openssl rand -hex 32      (or)      node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
JWT_SECRET=replace-with-a-long-random-secret

# Optional
JWT_EXPIRES_IN=7d
# Public origin the app is served from (used for Socket.io CORS). Must match
# where you open the app. For a domain: https://typeracer.example.com
CLIENT_ORIGIN=http://localhost:8080
# Host port that maps to the client (nginx). The app opens at this port.
APP_PORT=8080
